{
  "name": "TryMaar (Flutter)",
  // We use the CirrusLabs Flutter stable image because it comes pre-installed 
  // with Flutter, Dart, and the Android SDK, perfect for Codespaces.
  "image": "ghcr.io/cirruslabs/flutter:stable",
  
  "customizations": {
    "vscode": {
      "settings": {
        "dart.flutterSdkPath": "/sdks/flutter",
        "dart.debugExternalPackageLibraries": true,
        "dart.debugSdkLibraries": false
      },
      "extensions": [
        "dart-code.flutter",
        "dart-code.dart-code"
      ]
    }
  },

  // Forward port 8080 so we can preview Flutter Web in the browser
  "forwardPorts": [8080],

  // Automatically fetch dependencies when the Codespace is created
  "postCreateCommand": "flutter pub get",
  
  // Connect as the default user from the image
  "remoteUser": "cirrus"
}
