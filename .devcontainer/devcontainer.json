{
  "name": "TryMaar (Flutter)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "dart.flutterSdkPath": "/home/vscode/flutter",
        "dart.debugExternalPackageLibraries": true,
        "dart.debugSdkLibraries": false
      },
      "extensions": [
        "dart-code.flutter",
        "dart-code.dart-code"
      ]
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": "flutter pub get",
  "remoteUser": "vscode"
}
